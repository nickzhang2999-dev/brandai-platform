exports[`AIInsightPanel > renders conclusion + evidence + suggestions 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground p-6 shadow-sm flex flex-col gap-4"><div class="flex items-start justify-between gap-3"><p class="font-serif text-lg leading-snug">Palette drifts warm.</p><span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium bg-warning/15 text-warning">Needs attention</span></div><section><div class="mb-1 text-xs uppercase tracking-wide text-muted-foreground">Evidence</div><ul class="list-disc space-y-1 pl-5 text-sm"><li>12/15 assets use gold</li></ul></section><section><div class="mb-1 text-xs uppercase tracking-wide text-muted-foreground">Suggested actions</div><ul class="list-disc space-y-1 pl-5 text-sm"><li>Lock muted-gold</li></ul></section></div>"`;

exports[`BrandCanvas > renders eyebrow + title + children 1`] = `"<section class="rounded-3xl border border-foreground/10 bg-background p-8"><header class="mb-6 flex items-end justify-between gap-6"><div><div class="mb-2 text-xs uppercase tracking-[0.2em] text-accent">Workspace</div><h2 class="font-serif text-2xl md:text-3xl">Acme</h2></div></header><p>content</p></section>"`;

exports[`BrandDNAPanel > renders title + children 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground p-6 shadow-sm flex flex-col gap-5"><header class="flex flex-col gap-1"><h3 class="font-serif text-xl">Brand DNA</h3><p class="text-sm text-muted-foreground">auto-extracted</p></header><div class="flex flex-col gap-4"><div>inner</div></div></div>"`;

exports[`ConsistencyScoreCard > renders pass/risk/danger tones by score > danger 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground p-6 shadow-sm flex flex-col gap-1"><span class="text-xs uppercase tracking-wide text-muted-foreground">Danger</span><span class="font-serif text-5xl leading-none text-destructive">40<span class="ml-1 text-xl text-muted-foreground">/100</span></span><span class="text-xs text-muted-foreground">needs work</span></div>"`;

exports[`ConsistencyScoreCard > renders pass/risk/danger tones by score > pass 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground p-6 shadow-sm flex flex-col gap-1"><span class="text-xs uppercase tracking-wide text-muted-foreground">Pass</span><span class="font-serif text-5xl leading-none text-success">90<span class="ml-1 text-xl text-muted-foreground">/100</span></span></div>"`;

exports[`ConsistencyScoreCard > renders pass/risk/danger tones by score > risk 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground p-6 shadow-sm flex flex-col gap-1"><span class="text-xs uppercase tracking-wide text-muted-foreground">Risk</span><span class="font-serif text-5xl leading-none text-warning">70<span class="ml-1 text-xl text-muted-foreground">/100</span></span></div>"`;

exports[`VisualAssetCard > renders with thumb + tags + meta 1`] = `"<link rel="preload" as="image" href="/u/hero.png"/><div class="rounded-lg border border-border bg-card text-card-foreground shadow-sm flex flex-col gap-3 p-3"><div class="aspect-square w-full overflow-hidden rounded-lg bg-muted"><img src="/u/hero.png" alt="hero.png" class="h-full w-full object-cover"/></div><div class="flex flex-col gap-1 px-1"><div class="truncate text-sm font-medium" title="hero.png">hero.png</div><div class="text-xs text-muted-foreground">1920×1080 · 312 KB</div><div class="mt-1 flex flex-wrap gap-1"><span class="inline-flex items-center rounded-md px-2 py-0.5 font-medium border border-foreground/20 text-foreground/70 text-[10px]">primary</span><span class="inline-flex items-center rounded-md px-2 py-0.5 font-medium border border-foreground/20 text-foreground/70 text-[10px]">hero</span></div></div></div>"`;

exports[`VisualAssetCard > renders without thumb 1`] = `"<div class="rounded-lg border border-border bg-card text-card-foreground shadow-sm flex flex-col gap-3 p-3"><div class="aspect-square w-full overflow-hidden rounded-lg bg-muted"><div class="flex h-full w-full items-center justify-center text-xs text-muted-foreground">(no preview)</div></div><div class="flex flex-col gap-1 px-1"><div class="truncate text-sm font-medium" title="noimg.png">noimg.png</div></div></div>"`;
