# ---- Database ----
DATABASE_URL="postgresql://brandai:brandai@localhost:5432/brandai?schema=public"

# ---- Redis (BullMQ) ----
REDIS_URL="redis://localhost:6379"

# ---- S3 / MinIO ----
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="brandai"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_URL="http://localhost:9000/brandai"

# ---- Auth.js ----
AUTH_SECRET="dev-secret-change-me"
AUTH_URL="http://localhost:3000"
# M-B production auth. Email/password works with no extra config.
# Set these to offer GitHub / Google sign-in (left blank = button hidden):
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Passwordless demo login: OFF unless explicitly set to "1". Opt-in only for
# local dev / staging / e2e — it upserts any email and bypasses registration +
# password gates, so never enable it in production.
AUTH_ALLOW_DEMO="0"

# ---- Admin ----
# Comma-separated emails allowed into /admin/settings (platform AI key, etc.).
# Unset → nobody is admin (settings page locked). Safe default for open signup.
ADMIN_EMAILS=""
# Encrypts admin-supplied secrets (AI provider keys) at rest. Falls back to
# AUTH_SECRET when unset; rotating it orphans previously-stored keys.
SETTINGS_ENC_KEY=""

# ---- Feature flags ----
# M-A asset proxy (thumbnails over the public domain). Set 0 to use raw URLs.
NEXT_PUBLIC_ASSET_PROXY="1"
# M-D generation quota / rate-limit. Set 0 to disable enforcement.
QUOTA_V1="1"

# ---- AI service ----
AI_SERVICE_URL="http://localhost:8000"

# ---- AI service internal: provider selection ----
# IMAGE_PROVIDER / VLM_PROVIDER: provider NAME. "mock" (default, zero keys) |
# "openai" | "gemini" | "seeddream" | any label when *_BASE_URL is set.
# A real provider activates only when its *_API_KEY is also non-empty;
# otherwise the service silently stays on mock.
IMAGE_PROVIDER="mock"
VLM_PROVIDER="mock"
IMAGE_PROVIDER_API_KEY=""
VLM_PROVIDER_API_KEY=""
# Override the endpoint for OpenAI-compatible gateways (OpenRouter, one-api
# relays, self-hosted). Empty → built-in endpoint for the provider name above.
#   e.g. https://openrouter.ai/api/v1
IMAGE_PROVIDER_BASE_URL=""
VLM_PROVIDER_BASE_URL=""
# Model ids. Gateways require a namespaced id ("openai/gpt-image-1",
# "openai/gpt-4o"); OpenAI direct takes the bare id ("gpt-image-1", "gpt-4o").
# Empty IMAGE_MODEL → upstream default; empty VLM_MODEL → "gpt-4o".
IMAGE_MODEL=""
VLM_MODEL=""
AI_HTTP_TIMEOUT_SECONDS="60"
AI_MAX_RETRIES="3"
