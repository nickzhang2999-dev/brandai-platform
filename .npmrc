# OpenVisual · 包管理器配置
#
# store-dir = monorepo-local pnpm content-addressable store.
#
# Why: cds-compose.yml mounts the repo as `.:/app`. pnpm's default store
# lives at $HOME/.local/share/pnpm/store, which is INSIDE the container's
# writable layer and gets wiped on every container restart — forcing a
# full re-download of ~950MB of packages on every redeploy / OOM-restart.
#
# Putting the store under `.pnpm-store/` puts it inside the bind mount, so
# it survives container restarts within a single deploy. The store is
# content-addressable and hard-linked into node_modules, so the disk cost
# is bounded by what's actually in use.
#
# Across CDS *deploys* (fresh git checkout) the store still cold-starts;
# fixing that needs a named volume which is a cds-compose.yml change —
# saved for the next batch审批 (see docs/PRINCIPLES.md §X · "compose budget").
store-dir=.pnpm-store

# Default registry — explicit so we don't accidentally pull from a
# private mirror configured at the OS level on the CDS host.
registry=https://registry.npmjs.org/

# Be strict about peer-dep resolution so the lockfile is reproducible.
auto-install-peers=true
strict-peer-dependencies=false
